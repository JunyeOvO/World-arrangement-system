{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Task",
  "type": "object",
  "required": ["task_id", "project_id", "repo_path", "user_goal", "risk_level", "auto_execute", "auto_pr", "auto_merge", "status"],
  "properties": {
    "task_id": { "type": "string" },
    "project_id": { "type": "string" },
    "repo_path": { "type": "string" },
    "user_goal": { "type": "string" },
    "risk_level": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
    "allowed_paths": { "type": "array", "items": { "type": "string" } },
    "forbidden_paths": { "type": "array", "items": { "type": "string" } },
    "acceptance": { "type": "array", "items": { "type": "string" } },
    "task_mode": { "type": "string", "enum": ["read_only", "patch", "test", "docs", "audit"] },
    "expected_diff": { "type": "boolean" },
    "verification_policy": { "type": "string", "enum": ["none", "changed_files_only", "unit", "full"] },
    "read_budget_profile": { "type": "string", "enum": ["quick_triage", "code_contract_audit", "next_task_planning", "docs_review"] },
    "read_budget": {
      "type": "object",
      "properties": {
        "max_files": { "type": "integer", "minimum": 1 },
        "max_dirs": { "type": "integer", "minimum": 1 },
        "max_worker_turns": { "type": "integer", "minimum": 1 },
        "max_duration_sec": { "type": "integer", "minimum": 1 },
        "max_output_tokens": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "auto_execute": { "type": "boolean" },
    "auto_pr": { "type": "boolean" },
    "auto_merge": { "type": "boolean", "const": false },
    "status": { "type": "string" },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" }
  }
}
