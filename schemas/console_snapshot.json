{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://world.local/schemas/console_snapshot.json",
  "type": "object",
  "required": ["health", "tasks", "alerts", "heartbeats", "metrics", "models"],
  "properties": {
    "health": {
      "type": "object",
      "required": ["status", "running", "queued", "failed", "approval_waiting", "open_alerts", "cost_today_usd"],
      "properties": {
        "status": {"type": "string"},
        "running": {"type": "integer"},
        "queued": {"type": "integer"},
        "failed": {"type": "integer"},
        "approval_waiting": {"type": "integer"},
        "open_alerts": {"type": "integer"},
        "cost_today_usd": {"type": "number"}
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["task_id", "status", "raw_status", "display_status", "big_status", "console_group"],
        "properties": {
          "task_id": {"type": "string"},
          "status": {"type": "string"},
          "raw_status": {"type": "string"},
          "display_status": {"type": "string"},
          "big_status": {"type": "string", "enum": ["Running", "Queued", "Failed", "Approval", "Alerts", "Done", "Closed"]},
          "console_group": {"type": "string", "enum": ["running", "queued", "failed", "approval", "alerts", "none"]},
          "status_reason": {"type": "string"},
          "is_terminal": {"type": "boolean"},
          "requires_user_action": {"type": "boolean"}
        },
        "additionalProperties": true
      }
    },
    "alerts": {"type": "array"},
    "heartbeats": {"type": "array"},
    "metrics": {"type": "object"},
    "models": {"type": "array"}
  },
  "additionalProperties": true
}
